# === Discord ===
DISCORD_TOKEN=discord_bot_token_here
CLIENT_ID=discord_client_id_here
OWNER_ID=your_discord_userID_here

# === Lunaby ===
LUNABY_BASE_URL=https://api.lunie.dev/v1
LUNABY_API_KEY=api_key_here
# Optional: Override default model (defaults to lunaby-pro)
# LUNABY_MODEL=lunaby-pro
# Optional: Enable/disable streaming (defaults to true)
# Set to 'false' to disable streaming and use non-streaming responses
ENABLE_STREAMING=true

# === Dashboard ===
# CLIENT_SECRET=discord_client_secret_here
# CALLBACK_URL=http://localhost:3000/login/api
# DASHBOARD_PORT=3000

# === MongoDB ===
# example MONGODB_URI=mongodb://localhost:27017/luna
MONGODB_URI=uri_mongodb_here

# === SSL ===
# SSL Certificate Verification:
# - To enable SSL verification (recommended): NODE_TLS_REJECT_UNAUTHORIZED=1
# - To disable SSL verification (only if absolutely necessary): NODE_TLS_REJECT_UNAUTHORIZED=0
NODE_TLS_REJECT_UNAUTHORIZED=1
# Custom SSL Certificate
# CUSTOM_CA_CERT_PATH=/path/to/your/certificate.pem

# === MAL ===
# MAL_CLIENT_ID=your_mal_client_id_here